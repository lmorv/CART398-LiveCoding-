s0.initCam();

src(s0)
	.modulatePixelate(voronoi(30,0.32,0.5).scrollX(1,0.03),50)
	.kaleid(4)
	.colorama(0.2)
	.modulateScale(osc(1.5,0.5), 0.7)
	.modulateRotate(osc(2,0.5),0.7)
// 	.modulate(osc(2,0.1,0.3),2)
// 	.modulateKaleid(osc(16,0.1,0.1),6)
	.mult(shape(66, () => Math.sin(time) * 0.07 + 0.5, 0.4).scale(1.3, 9/16))
	.modulate(noise(1, 0.02), 0.04)
// 	.mult(s0,0.6) //try add, blend, diff, layer, mask, mult

	.out(o2)
render(o2)